{
  "hosting": {
    "public": "build/hosting",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/app/**",
        "destination": "/app/index.html"
      },
      {
        "source": "/webkit/**",
        "destination": "/webkit/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "lean-streak-project",
          "appId": "1:296684319013:android:b4da7fa1822509e4db6acc",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "lean-streak-project",
          "configurations": {
            "android": "1:296684319013:android:b4da7fa1822509e4db6acc",
            "ios": "1:296684319013:ios:d7d548a522e7dba6db6acc",
            "web": "1:296684319013:web:dc9c8e0064a127e9db6acc",
            "windows": "1:296684319013:web:cfa432a5adf4792cdb6acc"
          }
        }
      }
    }
  }
}
